        "nl": "Tweeledige nominale zin"
      },
      "definition": {
        "en": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "A nominal clause pattern that uses a predicate phrase plus a nexus pronoun rather than a present-tense verb “to be”."
              }
            ]
          }
        ],
        "nl": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Een nominaal zinsmodel dat een predicaatwoordgroep plus een verbindingsvoornaamwoord gebruikt in plaats van een tegenwoordige tijd van het werkwoord “zijn”."
              }
            ]
          }
        ]
      },
