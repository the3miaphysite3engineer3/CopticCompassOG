    {
      "id": "grammar.footnote.lesson01.005",
      "lessonId": "grammar.lesson.01",
      "content": {
        "en": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "In Coptic, there is no specific word for the neuter “it”."
              }
            ]
          }
        ],
        "nl": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "In het Koptisch is er geen specifiek woord voor “het”."
              }
            ]
          }
        ]
      },
      "sourceRefs": [
        "grammar.source.basisgrammatica-bohairisch-koptisch"
      ]
    },
    {
      "id": "grammar.footnote.lesson01.006",
      "lessonId": "grammar.lesson.01",
      "content": {
        "en": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "In older church books and presentations, this is often archaically written as "
              },
              {
                "type": "coptic",
                "text": "ϭⲟⲓⲥ"
              },
              {
                "type": "text",
                "text": ". The standard modern Bohairic spelling is "
              },
              {
                "type": "coptic",
                "text": "ϭⲱⲓⲥ"
              },
              {
                "type": "text",
                "text": "."
              }
            ]
          }
        ],
        "nl": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "In kerkelijke boeken en presentaties wordt dit vaak verouderd geschreven als "
              },
              {
                "type": "coptic",
                "text": "ϭⲟⲓⲥ"
              },
              {
                "type": "text",
                "text": ". De standaard Bohairische spelling is "
              },
              {
                "type": "coptic",
                "text": "ϭⲱⲓⲥ"
              },
              {
                "type": "text",
                "text": "."
              }
            ]
          }
        ]
      },
      "sourceRefs": [
        "grammar.source.basisgrammatica-bohairisch-koptisch"
      ]
    },
