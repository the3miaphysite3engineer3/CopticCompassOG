          {
            "type": "paragraph",
            "content": [
              {
                "type": "coptic",
                "text": "Ϩⲁⲛ-"
              },
              {
                "type": "text",
                "text": " < "
              },
              {
                "type": "coptic",
                "text": "ϩⲟⲓ̈ⲛⲉ"
              },
              {
                "type": "text",
                "text": " “sommige”. Er is geen Nederlands equivalent voor het onbepaald meervoud lidwoord "
              },
              {
                "type": "coptic",
                "text": "ϩⲁⲛ-"
              },
              {
                "type": "text",
                "text": "."
              }
            ]
          }
        ]
      },
      "sourceRefs": [
        "grammar.source.basisgrammatica-bohairisch-koptisch"
      ]
    },
