{
  "name": "coptic-compass",
  "description": "Coptic Compass: a digital home for Coptic study with dictionary, grammar, publications, and learning tools.",
  "version": "0.1.0",
  "private": true,
  "author": "Kyrillos Wannes",
  "license": "MIT",
  "engines": {
    "node": ">=22.13.0 <23"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KyroHub/CopticCompass.git"
  },
  "homepage": "https://kyrilloswannes.com",
  "bugs": {
    "url": "https://github.com/KyroHub/CopticCompass/issues"
  },
  "keywords": [
    "coptic",
    "linguistics",
    "dictionary",
    "digital-humanities",
    "nextjs",
    "typescript",
    "tailwindcss",
    "recharts"
  ],
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run data:grammar:export",
    "build": "next build --webpack",
    "start": "next start",
    "db:migrations:list": "supabase migration list --linked",
    "db:push:dry-run": "supabase db push --linked --dry-run",
    "db:push": "supabase db push --linked",
    "db:drift:check": "supabase db diff --linked --schema public",
    "data:grammar:export": "node --experimental-default-type=module --experimental-strip-types scripts/exportGrammar.mts",
    "lint": "eslint --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:local": "npm run build && npm run test:e2e",
    "knip": "knip"
  },
  "dependencies": {
    "@react-email/components": "^1.0.10",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "browser-image-compression": "^2.0.2",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.0",
    "resend": "^6.9.4",
    "swagger-ui-dist": "^5.32.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "eslint-plugin-import": "^2.31.0",
    "knip": "^5.88.1",
    "postcss": "^8.4.49",
    "prettier": "^3.5.3",
    "supabase": "^2.84.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
